Bootstrap: docker
From: julia:1.12.5

%help
    Grassmann Distance Worker - Julia Implementation

    GPU-accelerated conceptual path finding in embedding space.
    Uses KernelAbstractions.jl for vendor-neutral GPU compute (AMD/NVIDIA/CPU).
    Grassmann distance over local tangent spaces — graph construction,
    path finding, and topology analysis via FORGE MQTT dispatch.

    Required environment variables:
        MQTT_BROKER      - MQTT broker URL (e.g. tcp://broker:1883)
        MQTT_USER        - MQTT username
        MQTT_PASSWORD    - MQTT password
        JOB_ID           - Nomad job ID

    Optional environment variables:
        WORKER_ID        - Worker identifier (default: grassmann-{JOB_ID})
        USE_GPU          - Enable GPU compute (default: false)
        SYSIMAGE_PATH    - External sysimage path (default: /app/sysimage.so)

%files
    Project.toml /app/Project.toml
    Manifest.toml /app/Manifest.toml
    src /app/src
    test /app/test

%environment
    export JULIA_PROJECT=/app
    export JULIA_DEPOT_PATH=/opt/julia-depot
    export ROCM_PATH=/opt/rocm
    export LD_LIBRARY_PATH=/opt/rocm/lib:/opt/rocm/lib64:$LD_LIBRARY_PATH

%post
    export DEBIAN_FRONTEND=noninteractive
    export JULIA_DEPOT_PATH=/opt/julia-depot
    mkdir -p $JULIA_DEPOT_PATH

    # Install system dependencies
    apt-get update && apt-get install -y --no-install-recommends \
        gcc \
        g++ \
        libc-dev \
        libmosquitto-dev \
        libxml2 \
        libelf1 \
        libdrm2 \
        libdrm-amdgpu1 \
        libnuma1 \
        && rm -rf /var/lib/apt/lists/*

    # Install Julia dependencies
    cd /app
    julia --project=. -e 'using Pkg; Pkg.instantiate(); Pkg.precompile()'

    # Run tests as build validation
    echo "=== Running tests ==="
    julia --project=. test/runtests.jl

    # Verify
    echo "=== Verification ==="
    julia --project=. -e 'using GrassmannDistance; println("Package load OK")'

%runscript
    #!/bin/bash

    # Validate required environment
    for var in MQTT_BROKER MQTT_USER MQTT_PASSWORD JOB_ID; do
        if [ -z "${!var}" ]; then
            echo "ERROR: $var environment variable is required"
            exit 1
        fi
    done

    export WORKER_ID=${WORKER_ID:-"grassmann-${JOB_ID}"}
    export USE_GPU=${USE_GPU:-false}

    # Use external sysimage (NFS) if set, fall back to container-internal
    SYSIMAGE="${SYSIMAGE_PATH:-/app/sysimage.so}"
    SYSIMAGE_FLAG=""
    if [ -f "$SYSIMAGE" ]; then
        SYSIMAGE_FLAG="--sysimage=$SYSIMAGE"
    else
        echo "WARNING: No sysimage at $SYSIMAGE — JIT compilation (slow startup)"
    fi

    echo "Starting Grassmann Distance Worker (Julia)..."
    echo "  MQTT_BROKER: $MQTT_BROKER"
    echo "  JOB_ID: $JOB_ID"
    echo "  WORKER_ID: $WORKER_ID"
    echo "  USE_GPU: $USE_GPU"
    echo "  SYSIMAGE: $SYSIMAGE"

    exec julia --project=/app $SYSIMAGE_FLAG \
        -e 'using GrassmannDistance; exit(GrassmannDistance.julia_main())'
